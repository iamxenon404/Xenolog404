# =========================================================================
# 🪝 XENLOG404 OPEN-SOURCE DEPLOYMENT CONFIGURATION TEMPLATE
# Instructions: Copy this file to '.env.local' for local testing, or populate 
# these keys within your cloud provider's dashboard (Vercel, Render, etc.)
# =========================================================================

# 🌐 API BACKEND ORCHESTRATION PIPELINE
# The absolute production URL where your Express backend server is deployed.
# Ensure there is no trailing slash.
# Example: https://api.xenlog404.yourdomain.com
NEXT_PUBLIC_BACKEND_URL=

# 🔐 NEXTAUTH CORE SECURITY PARAMETERS
# The canonical root URL of your frontend application.
# Example: https://xenlog404.yourdomain.com
NEXTAUTH_URL=

# A secure, random 32-character string used to encrypt JWT tokens.
# You can generate a production-grade token in your terminal using:
# openssl rand -base64 32
NEXTAUTH_SECRET=

# 🐙 GITHUB APPLICATION OAUTH CREDENTIALS
# Required to handle registered developer persistence nodes.
# Generated via: GitHub Settings -> Developer Settings -> OAuth Apps -> New OAuth App
# Set the Authorization Callback URL to: <YOUR_NEXTAUTH_URL>/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=